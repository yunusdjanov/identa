{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-local.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "powershell -ExecutionPolicy Bypass -Command \"Set-Location ./backend; php artisan test\"",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sync-backend-db.ps1",
    "check:secrets": "powershell -ExecutionPolicy Bypass -Command \"Set-Location ./backend; php artisan security:check-secrets\"",
    "check:runtime-security": "powershell -ExecutionPolicy Bypass -Command \"Set-Location ./backend; php artisan security:check-runtime\"",
    "audit:frontend": "npm audit --audit-level=high",
    "audit:backend": "powershell -ExecutionPolicy Bypass -Command \"Set-Location ./backend; composer audit --locked\"",
    "audit:deps": "npm run audit:frontend && npm run audit:backend",
    "check:migrations": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check-backend-migrations.ps1",
    "test:e2e": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-e2e-cleanup.ps1 && playwright test",
    "test:e2e:headed": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-e2e-cleanup.ps1 && playwright test --headed",
    "perf:seed": "php scripts/perf-seed.php",
    "perf:snapshot": "php scripts/perf-snapshot.php",
    "quality:frontend": "npm run lint && npm run build && npm test",
    "quality:all": "npm run quality:frontend && npm run test:backend && npm run db:migrate && npm run check:migrations && npm run test:e2e",
    "quality:security": "npm run audit:deps",
    "release:preflight": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-preflight.ps1",
    "release:preflight:production": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-preflight.ps1 -Production"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
